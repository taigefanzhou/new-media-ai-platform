APP_NAME="New Media AI Platform"
DATABASE_URL="sqlite:///./data/platform.db"
STORAGE_DIR="./data/storage"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123456"
AUTH_SESSION_TTL_HOURS=12

# stub | openai-compatible | dify
# Recommended production priority:
# 1. Volcengine Ark / Doubao Seed for script and compliance generation.
# 2. Alibaba Cloud Bailian / Qwen as backup or specialist model.
LLM_PROVIDER="stub"
LLM_API_BASE="https://ark.cn-beijing.volces.com/api/v3"
LLM_API_KEY=""
LLM_MODEL="doubao-seed-2-0-pro-260215"

# Video generation
VIDEO_GENERATION_PROVIDER="mock"
SEEDANCE_API_BASE=""
SEEDANCE_API_KEY=""
SEEDANCE_MODEL="doubao-seedance-2-0-260128"
COMFYUI_API_BASE="http://localhost:8188"

# Voice and digital human
TTS_PROVIDER="mock"
TTS_API_BASE="http://localhost:9880"
TTS_API_KEY=""
TTS_VOICE="default"

DIGITAL_HUMAN_PROVIDER="sadtalker"
DIGITAL_HUMAN_API_BASE=""
DIGITAL_HUMAN_API_KEY=""

# Composition
COMPOSITION_PROVIDER="mock"
FFMPEG_BINARY="ffmpeg"
REMOTION_RENDER_API_BASE="http://remotion-renderer:3100"
REMOTION_RENDER_TEMPLATE="business_talking"

# Trending video search
TRENDING_SEARCH_PROVIDER="mock"
TRENDING_SEARCH_API_BASE=""
TRENDING_SEARCH_API_KEY=""

# Internal self-hosted WeChat Channels resolver. Keep the Yuanbao cookie outside the UI.
WECHAT_CHANNELS_RESOLVER_COOKIE=""

# Reference video/audio transcription
ASR_PROVIDER="mock"
ASR_API_BASE=""
ASR_API_KEY=""
ASR_MODEL="volcengine-asr"
